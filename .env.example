# ============================================================
# TonerPrint — Variables de entorno
# Copiar este archivo a .env.local y completar los valores
# NUNCA subir .env.local al repositorio
# ============================================================

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tonerprint_db
DB_USER=tonerprint_user
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# JWT — generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_STRING_ALEATORIO_LARGO_64_CARACTERES

# Entorno
NODE_ENV=production
PORT=3000

# URL pública del sitio (sin slash al final)
NEXT_PUBLIC_SITE_URL=https://tu-dominio.com
